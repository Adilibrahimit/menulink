# =============================================================================
# MenuLink · top-level .gitignore
# =============================================================================

# --- Secrets ---
# Never commit .env*.local — contains Supabase service_role and anon keys
.env
.env.local
.env.*.local
**/.env.local
**/.env.*.local

# --- Node / Next.js ---
node_modules/
**/node_modules/
.next/
**/.next/
out/
**/out/
*.tsbuildinfo
**/*.tsbuildinfo
next-env.d.ts
**/next-env.d.ts

# --- Supabase CLI ---
**/supabase/.branches/
**/supabase/.temp/
**/supabase/.env

# --- Graphify outputs (regenerable) ---
**/graphify-out/
.graphify_*

# --- Obsidian workspace (per-user UI state, not project content) ---
.obsidian/workspace
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/cache

# --- OS noise ---
.DS_Store
**/.DS_Store
Thumbs.db
**/Thumbs.db
desktop.ini
**/desktop.ini

# --- Editor noise ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- Logs ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Build artifacts ---
dist/
build/
*.tgz
